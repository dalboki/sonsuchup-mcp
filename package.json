{
  "name": "sonsuchup-mcp",
  "version": "0.1.1",
  "description": "MCP server for 손수첩 (Sonsuchup) — Connect the case-investigation web tool to Claude Desktop, Cursor, and other MCP clients.",
  "type": "module",
  "bin": {
    "sonsuchup-mcp": "dist/index.js"
  },
  "files": [
