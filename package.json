  "homepage": "https://github.com/dalboki/sonsuchup-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dalboki/sonsuchup-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/dalboki/sonsuchup-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@supabase/supabase-js": "^2.105.4",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
